APP_NAME=InduVista
APP_ENV=development

APP_TIMEZONE=Asia/Kolkata

# --- Report scheduler -------------------------------------------------------
# NOTE: these are read by .env but NOT yet consumed by any code (the reporting
# engine / scheduler is unbuilt — see roadmap Phase 20). They are kept here so
# the variable names are reserved and documented. Setting them today has no
# effect until the scheduler ships.
ENABLE_REPORT_SCHEDULER=true
REPORT_SCHEDULER_INTERVAL_SEC=30

# --- Database ---------------------------------------------------------------
POSTGRES_DB=induvista
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password

DATABASE_URL=postgresql+psycopg2://your_user:your_password@postgres:5432/induvista

# --- Valkey (frame-capture buffer) ------------------------------------------
# frame_capture.py (Frame Inspector) connects here. Defaults match the
# compose service name + port, so you usually don't need to set these.
# Frame capture is failure-safe: if valkey is unreachable it silently no-ops.
VALKEY_HOST=valkey
VALKEY_PORT=6379
